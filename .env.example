# Ballast — environment template. Copy to .env (gitignored). NEVER commit real secrets.

# --- Agent identity / signing ---
# Signing happens via TWAK + OS keychain. Do NOT put a private key here.
# The agent's on-chain address (public, safe to set) once registered:
BALLAST_AGENT_ADDRESS=

# --- CoinMarketCap AI Agent Hub (data) ---
# x402 keyless endpoint needs no API key; a key unlocks the authenticated MCP.
CMC_API_KEY=
CMC_MCP_URL=https://api.coinmarketcap.com/x402/mcp

# --- x402 settlement (agentcash USDC-on-Base wallet) ---
# Managed by the agentcash MCP server; no key stored here.
X402_SPEND_CAP_USD=5.00

# --- Trust Wallet Agent Kit (execution) ---
# twak reads its own keychain; only non-secret config here.
TWAK_RPC_URL=https://bsc-dataseed.binance.org
TWAK_NETWORK=bsc-mainnet

# --- BNB AI Agent SDK (ERC-8004 identity + x402 signing) ---
# Self-custody wallet key for the bnbagent SDK. NEVER commit a real key.
# Leave blank to stay in paper mode (no chain). Use a funded TESTNET key first.
BNB_WALLET_KEY=
BNB_WALLET_PASSWORD=ballast
GREENFIELD_BUCKET=ballast-journal
ERC8004_REGISTRY=

# --- Competition ---
COMPETE_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5

# --- Runtime ---
# paper | dry-run | live   (live requires twak + funded wallet; gated)
BALLAST_MODE=paper
BALLAST_PRESET=conservative
